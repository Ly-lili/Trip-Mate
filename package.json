{
  "name": "tripmate-agent",
  "version": "0.1.0",
  "description": "Travel planning agent built on DeepSeek + MCP, with CLI and Next.js web UI",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.cli.json --noEmit",
    "dev:web": "next dev -p 3000",
    "build:web": "next build",
    "start:web": "next start -p 3000"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "next": "^15.0.0",
    "openai": "^5.23.2",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "25.9.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "18.3.31",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
